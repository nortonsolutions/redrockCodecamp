extends ../layout
block content
	style.
		/* Social-first sign-up panel.
		   Styles mirror the icon-button pattern used in email-signin.jade so
		   the two pages look like part of the same flow. Each provider gets
		   its own class (.social-btn-google / -github / -apple) so we can
		   tweak colors, glyphs, or future per-provider behavior in one
		   place without touching the others. */
		.social-first-panel {
			margin: 18px auto 12px;
			max-width: 520px;
			background: #f8fafc;
			border: 1px solid #dbeafe;
			border-radius: 12px;
			padding: 16px;
			text-align: center;
		}
		.social-first-title {
			margin: 0 0 8px;
			font-size: 18px;
		}
		.social-first-copy {
			margin: 0 0 12px;
			font-size: 14px;
			color: #334155;
		}
		.social-btn-row {
			display: flex;
			flex-direction: row;
			justify-content: center;
			align-items: center;
			gap: 12px;
			width: 100%;
			margin: 4px 0 6px;
		}
		.social-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			flex: 0 0 auto;
			width: 52px;
			height: 52px;
			padding: 0;
			margin: 0;
			border-radius: 999px;
			text-decoration: none;
			font-size: 0; /* hide any stray text node */
			line-height: 1;
			transition: transform .15s ease, box-shadow .2s ease, opacity .2s ease;
		}
		.social-btn:hover {
			transform: translateY(-1px);
			text-decoration: none;
		}
		.social-btn svg {
			width: 24px;
			height: 24px;
			display: block;
		}
		.social-btn-google {
			color: #111827;
			background: #ffffff;
			border: 1px solid #dbeafe;
			box-shadow: 0 8px 24px rgba(59, 130, 246, .18);
		}
		.social-btn-github {
			color: #fff;
			background: #000;
			border: 1px solid #1f2937;
		}
		.social-btn-apple {
			color: #fff;
			background: #000;
			border: 1px solid #1f2937;
		}
		.social-disclaimer {
			margin: 6px 0 0;
			font-size: 11px;
			color: #6b7280;
		}
	.container
		.row
			.col-sm-8.col-sm-offset-2
				.social-first-panel
					h3.social-first-title Faster sign-up available
					p.social-first-copy One click with a social account, or use the form below if you prefer email/password.
					.social-btn-row
						a.social-btn.social-btn-google(href='/auth/google', aria-label='Continue with Google', title='Continue with Google')
							svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 48 48' aria-hidden='true' focusable='false')
								path(fill='#9c9ce6' d='M44.5,20H24v8.5h11.9C34.3,33.7,29.6,38,24,38c-7.2,0-13-5.8-13-13s5.8-13,13-13c3.2,0,6.1,1.2,8.3,3.1l6.2-6.1C34.4,7.1,29.4,5,24,5C12.3,5,3,14.3,3,26s9.3,21,21,21s21-9.3,21-21C45,22.7,44.8,21.4,44.5,20z')
						a.social-btn.social-btn-github(href='/auth/github', aria-label='Continue with GitHub', title='Continue with GitHub')
							svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='#a6ffa9' aria-hidden='true' focusable='false')
								path(d='M12 .5C5.73.5.99 5.24.99 11.51c0 4.86 3.15 8.98 7.52 10.43.55.1.75-.24.75-.53 0-.26-.01-.95-.02-1.86-3.06.66-3.71-1.48-3.71-1.48-.5-1.27-1.22-1.61-1.22-1.61-1-.68.08-.67.08-.67 1.1.08 1.68 1.13 1.68 1.13.98 1.68 2.58 1.2 3.21.92.1-.71.39-1.2.7-1.48-2.44-.28-5.01-1.22-5.01-5.43 0-1.2.43-2.18 1.13-2.95-.11-.28-.49-1.4.11-2.92 0 0 .92-.29 3.02 1.13a10.5 10.5 0 0 1 5.5 0c2.1-1.42 3.02-1.13 3.02-1.13.6 1.52.22 2.64.11 2.92.7.77 1.13 1.75 1.13 2.95 0 4.22-2.58 5.15-5.03 5.42.4.34.76 1.02.76 2.05 0 1.48-.01 2.67-.01 3.03 0 .29.2.64.76.53 4.36-1.46 7.51-5.58 7.51-10.43C23.01 5.24 18.27.5 12 .5z')
						a.social-btn.social-btn-apple(href='/auth/apple', aria-label='Continue with Apple', title='Continue with Apple')
							svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='#faafb6' aria-hidden='true' focusable='false')
								path(d='M16.365 1.43c0 1.14-.46 2.21-1.27 3.02-.84.85-1.93 1.5-3.02 1.41-.13-1.1.45-2.27 1.23-3.02.83-.83 2.05-1.45 3.06-1.41zM20.5 17.18c-.55 1.27-.81 1.84-1.52 2.97-.99 1.57-2.39 3.53-4.13 3.55-1.55.02-1.95-.99-4.06-.97-2.11.02-2.55 1-4.1.97-1.74-.02-3.06-1.79-4.05-3.36C.95 16.95.36 11.86 2.13 9.04c1.25-1.99 3.22-3.16 5.07-3.16 1.88 0 3.07 1.03 4.62 1.03 1.51 0 2.43-1.03 4.6-1.03 1.65 0 3.4.9 4.65 2.45-4.09 2.24-3.42 8.06-.57 8.85z')
					p.social-disclaimer We do not sell your data. Social sign-in only verifies identity.

	.container
		if flashMessage
			.row
				.col-sm-6.col-sm-offset-3.flashMessage.negative-30
					#flash-board.alert.alert-success.fade.in()
						button.close(type='button', data-dismiss='alert')
							span.ion-close-circled#flash-close
						#flash-content #{flashMessage}
                      

		.row
			.text-center
				h2 Sign up:
				.button-spacer
			.col-sm-6.col-sm-offset-3
				form(method='POST', action='/signup')
					input(type='hidden', name='_csrf', value=_csrf)
					.form-group
						input.input-lg.form-control.success-clear-value(type='email', name='email', id='email', value='#{email ? email : ""}', placeholder='Email', autofocus=true, required)
					.form-group
						input.input-lg.form-control.success-clear-value(type='text', name='name', id='name', value='#{name ? name : ""}', placeholder='Name', required)
					if settings.hasLocation
						.form-group
							input.input-lg.form-control.success-clear-value(type='text', name='location', id='location', value='#{location ? location : ""}', placeholder='Location')
					.form-group
						input.input-lg.form-control.success-clear-value(type='password', name='password', id='password', value='#{password ? password : ""}', placeholder='Password', required)
					.form-group
						input.input-lg.form-control.success-clear-value(type='password', name='confirmPassword', id='confirmPassword', value='#{confirmPassword ? confirmPassword : ""}', placeholder='Confirm Password', required)
					.button-spacer
						button#magic-btn.btn.btn-primary.btn-lg.btn-block(type='submit')
							span Sign up

		.row
			.text-center
				h3 Or
				h2
					a(href='/signin', style='font-weight:normal;font-size:inherit') Sign In here 