                            p.social-disclaimer We do not sell your data. Social sign-in only verifies identity.

                        details.email-options
                            summary Use email and password instead
                            .email-options-body
                                form.auth-form(method='POST', action='/signin')
                                    input(type='hidden', name='_csrf', value=_csrf)
                                    .form-group(style='padding-top:6px;')
                                        label(for='email') Email
                                        input.form-control(type='email', name='email', id='email', autocomplete='email', value='#{email ? email : ""}', placeholder='you@example.com', autofocus=true, required)
