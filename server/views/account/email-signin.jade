extends ../layout

block content
    style.
        body {
            background-color:#000;
            color:#fff;
            font-family:'Segoe UI', Arial, sans-serif;
            width:100%; height:100%; margin:0; padding:0;
        }
        .container {
            background-color:#000;
        }
        .signin-shell {
            position:relative;
            width:100%;
            max-width:1240px;
            margin:0 auto;
            padding:18px 0 24px;
        }
        .signin-hero {
            position:relative;
            width:100%;
            min-height:420px;
            padding-right:380px;
        }
        .video-section {
            width:100%;
            background-color:#000;
        }
        .video-container {
            border-radius:14px;
            overflow:hidden;
            width:100%;
            height:min(72vh, 760px);
            min-height:420px;
            box-shadow:0 22px 70px rgba(0,0,0,0.6);
            position:relative;
            margin:0;
            display:flex;
            align-items:center;
            justify-content:center;
            transition:box-shadow .3s ease;
            border:1px solid #1f2937;
        }
        .video-container.is-loading::after {
            content:'Loading…';
            position:absolute;
            top:0; left:0; right:0; bottom:0;
            display:flex; align-items:center; justify-content:center;
            background:rgba(0,0,0,.55);
            color:#fff; font-size:14px; letter-spacing:.04em;
            pointer-events:none;
        }
        @keyframes pulseRing {
            0%   { box-shadow:0 0 0 0   rgba(37,99,235,.85); }
            100% { box-shadow:0 0 0 18px rgba(37,99,235,0);   }
        }
        .video-container.flash { animation:pulseRing 900ms ease-out 1; }
        video#redrockMainVideo {
            width:100%;
            height:100%;
            object-fit:contain;
            display:block;
        }
        .auth-floating {
            position:absolute;
            top:26px;
            right:20px;
            width:340px;
            max-width:calc(100% - 40px);
            padding:14px 14px 12px;
            border-radius:12px;
            background:rgba(2, 6, 23, .82);
            border:1px solid rgba(148, 163, 184, .3);
            box-shadow:0 14px 40px rgba(0,0,0,.45);
            backdrop-filter:blur(4px);
        }
        /* Darken blacks on the initial autoplay sequence */
        video#redrockMainVideo.enhance-black {
            filter:brightness(.75) contrast(1.35) saturate(.9);
        }
        .form-control {
            text-align:center;
            background-color:#000;
            border-color:#444;
            color:#fff;
            border-radius:4px;
            height:36px;
        }
        .form-control:hover {cursor:pointer; color:#fff; border-color:#2563eb;}
        .inline-link {color:#2563eb; display:block; text-align:center; margin-top:10px; font-size:12px; margin-left:auto; margin-right: auto;}
        .inline-link.active {background-color:#1a365d; border-color:#2563eb; color:#fff;}
        .external-link {color:#2563eb; display:block; text-align:center; margin-top:10px; font-size:12px; margin-left:auto; margin-right: auto;}
        #magic-btn {background-color:#2563eb; border:none; border-radius:4px; padding:0 8px; width:270px;}

        .social-auth {
            width:100%;
            max-width:100%;
            margin:0 auto 8px;
            text-align:center;
        }
        .social-auth-title {
            font-size:22px;
            margin:0 0 8px;
            letter-spacing:.01em;
        }
        .social-auth-subtitle {
            color:#c7d2fe;
            font-size:13px;
            margin:0 0 10px;
            opacity:.95;
        }
        .social-btn {
            display:flex;
            align-items:center;
            justify-content:center;
            gap:8px;
            width:100%;
            height:40px;
            margin:0 auto 8px;
            border-radius:999px;
            text-decoration:none;
            font-size:14px;
            font-weight:600;
            transition:transform .15s ease, box-shadow .2s ease, opacity .2s ease;
        }
        .social-btn:hover {
            transform:translateY(-1px);
            text-decoration:none;
        }
        .social-btn-google {
            color:#111827;
            background:linear-gradient(180deg, #ffffff 0%, #eef2ff 100%);
            border:1px solid #dbeafe;
            box-shadow:0 8px 24px rgba(59,130,246,.18);
        }
        .social-btn-apple {
            color:#9ca3af;
            background:#0b1220;
            border:1px solid #1f2937;
            cursor:not-allowed;
            opacity:.65;
            pointer-events:none;
        }
        .social-disclaimer {
            margin:2px 0 0;
            font-size:11px;
            color:#9ca3af;
        }
        details.email-options {
            width:100%;
            margin-top:8px;
            border:1px solid #1e3a8a;
            border-radius:8px;
            background:#020617;
            padding:6px 10px 10px;
        }
        details.email-options summary {
            color:#93c5fd;
            text-align:center;
            cursor:pointer;
            outline:none;
            list-style:none;
            font-size:13px;
            margin:2px 0 2px;
        }
        details.email-options summary::-webkit-details-marker {display:none;}
        .email-options-body {
            margin-top:8px;
        }

        .alt-signup {text-align: center; margin-top: 20px; font-size: 12px;}
        .alt-signup a {color: #2563eb;}
        .form-panel {
            width:100%;
            max-width:100%;
            display:flex;
            flex-direction:column;
            align-items:center;
        }
        form.auth-form {
            width:100%;
            display:flex;
            flex-direction:column;
            align-items:center;
        }
        form.auth-form .form-group {
            width:100%;
            text-align:left;
        }
        form.auth-form button#magic-btn {
            margin-top:6px;
            width:100%;
        }
        .video-links {
            display:grid;
            grid-template-columns:repeat(2, minmax(0, 1fr));
            gap:10px;
            width:100%;
            max-width:980px;
            margin:14px auto 0;
        }
        .inline-link, .external-link {
            width:100%;
            margin-top:0;
            border-radius:8px;
        }
        @media (max-width: 991px) {
            .signin-hero {
                padding-right:0;
                min-height:0;
            }
            .auth-floating {
                position:static;
                width:100%;
                max-width:520px;
                margin:14px auto 0;
            }
        }
        @media (max-width: 768px) {
            .signin-shell {
                padding-top:0;
            }
            .video-section {
                width:100vw;
                margin-left:calc(50% - 50vw);
            }
            .video-container {
                border-radius:0;
                height:calc(100vw * 9 / 16);
                min-height:0;
                max-height:70vh;
                border-left:0;
                border-right:0;
            }
            .auth-floating {
                margin:12px 10px 0;
                max-width:none;
            }
            .video-links {
                grid-template-columns:1fr;
                margin-top:10px;
            }
        }

    .container(style='padding-top:12px; min-height:calc(100vh - 160px); color:#fff; width:100%; height:100%;')
        .signin-shell
            .signin-hero
                .video-section
                    .video-container
                        // NOTE: no controls attribute; muted for autoplay
                        video#redrockMainVideo(autoplay loop muted playsinline preload='auto' data-state='auto')
                            source(src='/assets/videos/redrockcode_intro_0_1080.mp4', type='video/mp4')
                            | Your browser does not support the video tag.
                .auth-floating
                    .form-panel
                        .social-auth
                            h2.social-auth-title Sign in fast
                            p.social-auth-subtitle One click with your provider. Email sign-in is still available below.
                            a.social-btn.social-btn-google(href='/auth/google') Continue with Google
                            a.social-btn.social-btn-apple(href='javascript:void(0)', aria-disabled='true') Continue with Apple (coming soon)
                            p.social-disclaimer We do not sell your data. Social sign-in only verifies identity.

                        details.email-options
                            summary Use email and password instead
                            .email-options-body
                                form.auth-form(method='POST', action='/signin')
                                    input(type='hidden', name='_csrf', value=_csrf)
                                    .form-group(style='padding-top:6px;')
                                        label(for='email') Email
                                        input.form-control(type='email', name='email', id='email', autocomplete='email', value='#{email ? email : ""}', placeholder='you@example.com', autofocus=true, required)
                                    .form-group
                                        label(for='password') Password
                                        input.form-control(type='password', name='password', id='password', autocomplete='current-password', placeholder='••••••••', required)
                                    button#magic-btn.btn.btn-primary.btn-block(type='submit') Sign In with Email
                                    div.alt-signup(style='width: 100%; margin-top: 12px;')
                                        if !settings.isSignUpDisabled
                                            span Prefer email account creation?
                                            a(href='/signup')   Create one

            .video-links
                a.form-control.inline-link(data-video='/assets/videos/redrockcode_intro_1.mp4' href='javascript:void(0)')  2 minutes: Introduction to Redrock Code
                a.form-control.inline-link(data-video='/assets/videos/redrockcode_intro_2.mp4' href='javascript:void(0)') 13 minutes: What will I learn?
                a.form-control.inline-link(data-video='/assets/videos/redrockcode_intro_3.mp4' href='javascript:void(0)') How to upgrade my membership?
                a.form-control.external-link(target='_blank' href='https://silvermedal.online') * Check out our game demo *
    script.
        const player = document.getElementById('redrockMainVideo');
        const container = document.querySelector('.video-container');

        function flashContainer() {
            if (!container) return;
            container.classList.remove('flash');
            // force reflow so the animation can restart
            void container.offsetWidth;
            container.classList.add('flash');
            container.classList.add('is-loading');
            container.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function changeVideo(videoSrc) {
            if (!videoSrc) return;
            player.removeAttribute('autoplay');
            player.removeAttribute('loop');
            player.classList.remove('enhance-black');
            player.src = videoSrc;
            player.muted = false;
            player.controls = true;
            player.load();

            const onCanPlay = () => {
                player.removeEventListener('canplay', onCanPlay);
                const p = player.play();
                if (p && typeof p.catch === 'function') {
                    p.catch(() => {
                        // Browser blocked unmuted playback; fall back to muted.
                        player.muted = true;
                        player.play().catch(() => {});
                    });
                }
            };
            player.addEventListener('canplay', onCanPlay);
            player.addEventListener('playing', () => {
                if (container) container.classList.remove('is-loading');
            }, { once: true });

            flashContainer();
        }

        document.addEventListener('DOMContentLoaded', () => {
            const links = document.querySelectorAll('.inline-link');

            links.forEach(link => {
                link.addEventListener('click', e => {
                    e.preventDefault();
                    links.forEach(l => l.classList.remove('active'));
                    link.classList.add('active');
                    changeVideo(link.getAttribute('data-video'));
                });
            });
        });
