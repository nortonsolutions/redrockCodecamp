extends ../layout

block content
    style.
        body {
            background-color:#000;
            color:#fff;
            font-family:'Segoe UI', Arial, sans-serif;
            width:100%; height:100%; margin:0; padding:0;
            /* Prevent the .video-section full-bleed (width:100vw) trick on
               mobile from triggering a horizontal scrollbar. */
            overflow-x:hidden;
        }
        .container {
            background-color:#000;
            /* Same: keep any inner full-bleed elements from causing scroll. */
            overflow-x:hidden;
        }
        .signin-shell {
            position:relative;
            width:100%;
            max-width:1240px;
            margin:0 auto;
            padding:18px 0 24px;
            box-sizing:border-box;
        }
        .signin-hero {
            position:relative;
            width:100%;
            min-height:420px;
            padding-right:380px;
        }
        .video-section {
            width:100%;
            background-color:#000;
        }
        .video-container {
            border-radius:14px;
            overflow:hidden;
            width:100%;
            /* Desktop: size by aspect ratio so the box is no taller than
               the actual video plus a little breathing room. The auth-floating
               panel sits at the top right of .signin-hero, so aligning the
               video to the top here keeps them visually aligned. */
            height:auto;
            aspect-ratio:16 / 9;
            max-height:min(72vh, 760px);
            min-height:0;
            box-shadow:0 22px 70px rgba(0,0,0,0.6);
            position:relative;
            margin:0;
            display:flex;
            align-items:flex-start;
            justify-content:center;
            transition:box-shadow .3s ease;
            border:1px solid #1f2937;
        }
        .video-container.is-loading::after {
            content:'Loading…';
            position:absolute;
            top:0; left:0; right:0; bottom:0;
            display:flex; align-items:center; justify-content:center;
            background:rgba(0,0,0,.55);
            color:#fff; font-size:14px; letter-spacing:.04em;
            pointer-events:none;
        }
        @keyframes pulseRing {
            0%   { box-shadow:0 0 0 0   rgba(37,99,235,.85); }
            100% { box-shadow:0 0 0 18px rgba(37,99,235,0);   }
        }
        .video-container.flash { animation:pulseRing 900ms ease-out 1; }
        video#redrockMainVideo {
            width:100%;
            height:100%;
            object-fit:contain;
            display:block;
        }
        .auth-floating {
            position:absolute;
            top:26px;
            right:20px;
            width:340px;
            max-width:calc(100% - 40px);
            padding:14px 14px 12px;
            border-radius:12px;
            background:rgba(2, 6, 23, .82);
            border:1px solid rgba(148, 163, 184, .3);
            box-shadow:0 14px 40px rgba(0,0,0,.45);
            backdrop-filter:blur(4px);
        }
        /* Darken blacks on the initial autoplay sequence */
        video#redrockMainVideo.enhance-black {
            filter:brightness(.75) contrast(1.35) saturate(.9);
        }
        .form-control {
            text-align:center;
            background-color:#000;
            border-color:#444;
            color:#fff;
            border-radius:4px;
            height:36px;
        }
        .form-control:hover {cursor:pointer; color: #fff; border-color: #82a2e8;}
        .inline-link {color: #82a2e8; display:block; text-align:center; margin-top:10px; font-size:12px; margin-left:auto; margin-right: auto;}
        .inline-link.active {background-color: #1a365d; border-color: #82a2e8; color:#fff;}
        .external-link {color: #82a2e8; display:block; text-align:center; margin-top:10px; font-size:12px; margin-left:auto; margin-right: auto;}
        #magic-btn {background-color: #82a2e8; border:none; border-radius:4px; padding:0 8px; width:270px;}

        .social-auth {
            width:100%;
            max-width:100%;
            margin:0 auto 8px;
            text-align:center;
        }
        .social-auth-title {
            font-size:22px;
            margin:0 0 8px;
            letter-spacing:.01em;
        }
        .social-auth-subtitle {
            color:#c7d2fe;
            font-size:13px;
            margin:0 0 10px;
            opacity:.95;
        }
        .start-anon-btn {
            display:flex;
            flex-direction:column;
            align-items:center;
            justify-content:center;
            text-decoration:none;
            background:linear-gradient(135deg, #16a34a, #15803d);
            color:#fff;
            border:1px solid #22c55e;
            border-radius:8px;
            padding:10px 14px;
            margin:0 0 12px;
            box-shadow:0 6px 18px rgba(34,197,94,.35);
            transition:transform .15s ease, box-shadow .15s ease, background .15s ease;
        }
        .start-anon-btn:hover,
        .start-anon-btn:focus {
            background:linear-gradient(135deg, #15803d, #166534);
            box-shadow:0 8px 22px rgba(34,197,94,.55);
            transform:translateY(-1px);
            color:#fff;
            text-decoration:none;
            outline:none;
        }
        .start-anon-label {
            font-size:20px;
            font-weight:700;
            letter-spacing:.02em;
            line-height:1.1;
        }
        .start-anon-sub {
            font-size:12px;
            opacity:.9;
            margin-top:2px;
            letter-spacing:.04em;
            text-transform:lowercase;
        }
        .social-btn-row {
            display:flex;
            flex-direction:row;
            justify-content:center;
            align-items:center;
            gap:10px;
            width:100%;
            margin:0 0 8px;
        }
        .social-btn {
            display:inline-flex;
            align-items:center;
            justify-content:center;
            flex:0 0 auto;
            width:48px;
            height:48px;
            padding:0;
            margin:0;
            border-radius:999px;
            text-decoration:none;
            font-size:0; /* hide any stray text node */
            line-height:1;
            transition:transform .15s ease, box-shadow .2s ease, opacity .2s ease;
        }
        .social-btn:hover {
            transform:translateY(-1px);
            text-decoration:none;
        }
        .social-btn svg {
            width:22px;
            height:22px;
            display:block;
        }
        .social-btn-google {
            color:#111827;
            //- background:linear-gradient(180deg, #ffffff 0%, #eef2ff 100%);
            //- border:1px solid #dbeafe;
            box-shadow:0 8px 24px rgba(59,130,246,.18);
        }
        .social-btn-apple {
            color: #fff;
            background: #000;
            border:1px solid #1f2937;
        }
        .social-btn-github {
            color: #fff;
            background: #000;
            border:1px solid #1f2937;
        }
        .social-disclaimer {
            margin:2px 0 0;
            font-size:11px;
            color:#9ca3af;
        }
        details.email-options {
            width:100%;
            margin-top:8px;
            border:1px solid #1e3a8a;
            border-radius:8px;
            background:#020617;
            padding:6px 10px 10px;
        }
        details.email-options summary {
            color:#93c5fd;
            text-align:center;
            cursor:pointer;
            outline:none;
            list-style:none;
            font-size:13px;
            margin:2px 0 2px;
        }
        details.email-options summary::-webkit-details-marker {display:none;}
        .email-options-body {
            margin-top:8px;
        }

        .alt-signup {text-align: center; margin-top: 20px; font-size: 12px;}
        .alt-signup a {color: #2563eb;}
        .form-panel {
            width:100%;
            max-width:100%;
            display:flex;
            flex-direction:column;
            align-items:center;
        }
        form.auth-form {
            width:100%;
            display:flex;
            flex-direction:column;
            align-items:center;
        }
        form.auth-form .form-group {
            width:100%;
            text-align:left;
        }
        form.auth-form button#magic-btn {
            margin-top:6px;
            width:100%;
        }
        .video-links {
            /* Align the links bar visually with the video container above.
               On desktop the video shares the hero row with .auth-floating
               (which is pinned to the right with a 380px reserve via
               .signin-hero padding-right), so the links get the same
               reserve to line up with the video's right edge. The 991px
               breakpoint below resets this when the auth panel stacks
               beneath the video. */
            display:flex;
            flex-wrap:wrap;
            justify-content:center;
            align-items:stretch;
            gap:10px;
            width:100%;
            max-width:none;
            margin:14px 0 0;
            padding-right:380px;
            box-sizing:border-box;
        }
        .video-links > a {
            flex:1 1 220px;
            min-width:0;
        }
        .inline-link, .external-link {
            width:100%;
            margin-top:0;
            border-radius:8px;
        }
        @media (max-width: 991px) {
            .signin-hero {
                padding-right:0;
                min-height:0;
            }
            .auth-floating {
                position:static;
                width:100%;
                max-width:520px;
                margin:14px auto 0;
            }
            .video-links {
                /* Auth panel has stacked below the video now, so reclaim
                   the right-side reserve and let the links span full width. */
                padding-right:0;
            }
        }
        @media (max-width: 768px) {
            .signin-shell {
                padding-top:0;
                padding-left:0;
                padding-right:0;
            }
            .video-section {
                width:100vw;
                margin-left:calc(50% - 50vw);
                max-width:100vw;
            }
            .video-container {
                border-radius:0;
                height:calc(100vw * 9 / 16);
                min-height:0;
                max-height:70vh;
                border-left:0;
                border-right:0;
            }
            .auth-floating {
                margin:12px 10px 0;
                width:auto;
                max-width:calc(100vw - 20px);
                box-sizing:border-box;
            }
            .video-links {
                /* Stack links full-width on phones; keep small side gutters
                   so they don't bleed to the screen edge. */
                flex-direction:column;
                flex-wrap:nowrap;
                padding:0 10px;
                margin-top:10px;
            }
            .video-links > a {
                flex:0 0 auto;
            }
        }

