extends ../layout

block content
  .container-fluid
    .row
      .col-md-12
        .portfolio-header.text-center
          h1.display-4 
            i.fa.fa-code
            |  Norton Solutions Portfolio
          p.lead Complete, browsable implementations — from FreeCodeCamp builds to the full Red Rock Code signature curriculum.
          hr

        // ===== Signature Curriculum (Red Rock Code originals) =====
        .signature-section.mb-5
          .signature-hero.text-center
            span.signature-badge ⭐ Signature Curriculum
            h2.mt-3.mb-2 The Red Rock Code Workbench
            p.signature-lede
              | What makes Red Rock Code unique: teaching #[strong standard ES6/PWA/SPA module programming] from the
              | ground up — MVC and OOP principles throughout, #[code &lt;script type="module"&gt;] and clean browser APIs.
              | No framework mess. Write the code once; ship it to web, iOS, and Android as a PWA.
              | A bet we made in 2017 — and the right one.
            a.btn.btn-signature.btn-lg.mt-2(href='https://redrockcode.com/educationMaterials/workbenchProjects/review/' target='_blank' rel='noopener')
              i.fa.fa-folder-open.mr-2
              |  Browse All Workbench Implementations →
          .row.mt-4
            .col-md-4.mb-3
              .signature-card
                h5
                  i.fa.fa-heartbeat.text-danger.mr-1
                  |  ES6 Project Series
                p.small.text-muted Every step, fully implemented — some with multiple variants.
                ul.signature-list
                  li Virtual Life — every step of the animated life simulation
                  li User Management Page — every step, MVC from scratch
                  li
                    | Bluesky — complete real-estate SPA
                    a.ml-1(href='https://redrockbluesky.org' target='_blank' rel='noopener') (live demo)
            .col-md-4.mb-3
              .signature-card
                h5
                  i.fa.fa-paint-brush.text-info.mr-1
                  |  Responsive Web Design
                p.small.text-muted Terms 1 &amp; 2 — heavy on HTML and CSS. Still vital to know and love, as relevant now as ever.
                ul.signature-list
                  li Epilogue
                  li Industrious
                  li Visualize
                  li Interphase
            .col-md-4.mb-3
              .signature-card
                h5
                  i.fa.fa-graduation-cap.text-success.mr-1
                  |  Classic Capstones
                p.small.text-muted Solutions to respected outside curricula, integrated into the camp.
                ul.signature-list
                  li Platform Game — Eloquent JavaScript
                  li Personality Quiz — Stanford CS 193X
                  li Quizzap Quiz Timer — our original React build
          .signature-footer.text-center.mt-3
            p.mb-2
              | Certifications are issued for every completed term of the Code Camp (courses 1000–3090) —
              a.ml-1(href='https://redrockcode.com/en/9fab1f75' target='_blank' rel='noopener') see Dave's public profile with the full code portfolio and certifications
              | .
            p.small.text-muted.mb-0
              | In the works: CS 106A + 108 materials and a “Robotics” extension of Programming Methodologies
              | (think Karel meets Arduino / Raspberry Pi with physical moving parts) — with accreditation
              | being pursued in the state of Utah.

        .fcc-divider.text-center.mb-4
          h3.mb-1 FreeCodeCamp Track
          p.text-muted #{totalProjects} complete implementations — APIs, security, and React

        .projects-overview
          .row
            each category in projects
              .col-md-4.mb-4
                .card.portfolio-card
                  .card-header.text-center
                    h2 #{category.icon} #{category.name}
                  .card-body
                    p.card-text= category.description
                    .project-list
                      each project in category.projects
                        .project-item.mb-2
                          a.btn.btn-sm.btn-outline-primary.project-link(href=project.path) #{project.name}
                          small.text-muted.d-block= project.description
                    if category.id === 'apis'
                      .mt-3
                        a.btn.btn-info.btn-sm(href='/portfolio/apis/test') 
                          i.fa.fa-flask
                          |  API Testing Interface
                  .card-footer.text-center
                    a.btn.btn-primary(href=category.path) 
                      | View All #{category.name}
                      i.fa.fa-arrow-right.ml-2
        
        .portfolio-features.mt-5
          .row
            .col-md-4
              .feature-box.text-center
                i.fa.fa-server.fa-3x.text-primary
                h4 Backend APIs
                p Full Express.js microservices with MongoDB integration
            .col-md-4
              .feature-box.text-center
                i.fa.fa-shield.fa-3x.text-success
                h4 Security & Testing
                p Advanced authentication, bcrypt, and comprehensive testing
            .col-md-4
              .feature-box.text-center
                i.fa.fa-react.fa-3x.text-info
                h4 React Frontend
                p Interactive applications with state management and hooks

  style.
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
      min-height: 100vh;
    }
    .portfolio-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 4rem 0;
      margin: -20px -15px 40px -15px;
      position: relative;
      overflow: hidden;
    }
    .portfolio-header::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(255,255,255,0.1);
    }
    .portfolio-header > * {
      position: relative;
      z-index: 1;
    }
    /* ---- Signature Curriculum section ---- */
    .signature-section {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      border-radius: 20px;
      padding: 3rem 2rem 2rem;
      color: #e2e8f0;
      box-shadow: 0 12px 48px rgba(15, 23, 42, 0.35);
    }
    .signature-badge {
      display: inline-block;
      background: linear-gradient(135deg, #f59e0b, #d97706);
      color: #fff;
      font-weight: 600;
      font-size: .85rem;
      letter-spacing: .06em;
      text-transform: uppercase;
      padding: .4rem 1.1rem;
      border-radius: 999px;
    }
    .signature-hero h2 { color: #fff; font-weight: 600; }
    .signature-lede {
      max-width: 760px;
      margin: 0 auto 1rem;
      color: #cbd5e1;
      line-height: 1.7;
    }
    .signature-lede code { color: #7dd3fc; background: rgba(125,211,252,.1); padding: .1em .35em; border-radius: 6px; }
    .btn-signature {
      background: linear-gradient(135deg, #f59e0b, #d97706);
      color: #fff !important;
      border: none;
      border-radius: 12px;
      font-weight: 600;
      padding: .85rem 1.75rem;
      text-decoration: none !important;
    }
    .btn-signature:hover {
      filter: brightness(1.1);
      box-shadow: 0 6px 20px rgba(245, 158, 11, 0.4);
      color: #fff;
    }
    .signature-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 14px;
      padding: 1.5rem;
      height: 100%;
    }
    .signature-card h5 { color: #fff; font-weight: 600; margin-bottom: .5rem; }
    .signature-card .text-muted { color: #94a3b8 !important; }
    .signature-list {
      list-style: none;
      padding-left: 0;
      margin-bottom: 0;
    }
    .signature-list li {
      padding: .35rem 0 .35rem 1.4rem;
      position: relative;
      color: #e2e8f0;
      font-size: .92rem;
    }
    .signature-list li::before {
      content: '\2713';
      position: absolute;
      left: 0;
      color: #34d399;
      font-weight: 700;
    }
    .signature-list a, .signature-footer a { color: #7dd3fc; text-decoration: none; }
    .signature-list a:hover, .signature-footer a:hover { color: #bae6fd; text-decoration: underline; }
    .signature-footer { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1.25rem; color: #cbd5e1; }
    .signature-footer .text-muted { color: #94a3b8 !important; }
    .fcc-divider h3 { font-weight: 600; color: #1e293b; }
    .display-4 {
      font-weight: 300;
      letter-spacing: -0.02em;
    }
    .lead {
      font-weight: 300;
      opacity: 0.9;
    }
    .portfolio-card {
      border: none;
      background: rgba(255,255,255,0.95);
      box-shadow: 0 8px 32px rgba(31, 38, 135, 0.15);
      border-radius: 16px;
      height: 100%;
    }
    .portfolio-card:hover {
      box-shadow: 0 12px 48px rgba(31, 38, 135, 0.25);
    }
    .portfolio-card .card-header {
      background: linear-gradient(135deg, rgba(255,255,255,0.8) 0%, rgba(248,250,252,0.8) 100%);
      border-bottom: 1px solid rgba(226, 232, 240, 0.5);
      border-radius: 16px 16px 0 0 !important;
      padding: 1.5rem;
    }
    .portfolio-card .card-header h2 {
      font-size: 1.4rem;
      font-weight: 600;
      margin: 0;
      color: #1e293b;
    }
    .portfolio-card .card-body {
      padding: 1.5rem;
    }
    .portfolio-card .card-footer {
      background: transparent;
      border-top: 1px solid rgba(226, 232, 240, 0.3);
      padding: 1.5rem;
      border-radius: 0 0 16px 16px;
    }
    .project-item {
      padding: 1rem;
      background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
      border-radius: 12px;
      border: 1px solid rgba(226, 232, 240, 0.6);
      margin-bottom: 0.75rem;
    }
    .project-item:hover {
      background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
    }
    .project-link {
      text-decoration: none !important;
      font-weight: 500;
      color: #3730a3 !important;
      display: block;
      margin-bottom: 0.25rem;
    }
    .btn-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border: none;
      border-radius: 12px;
      padding: 0.75rem 1.5rem;
      font-weight: 500;
    }
    .btn-primary:hover {
      background: linear-gradient(135deg, #5a67d8 0%, #6b46c1 100%);
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }
    .btn-outline-primary {
      border: 2px solid #667eea;
      color: #667eea;
      border-radius: 8px;
      font-weight: 500;
    }
    .btn-outline-primary:hover {
      background: #667eea;
      border-color: #667eea;
      color: white;
    }
    .btn-info {
      background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
      border: none;
      border-radius: 8px;
      font-weight: 500;
    }
    .feature-box {
      padding: 2.5rem;
      background: rgba(255,255,255,0.9);
      border-radius: 20px;
      box-shadow: 0 8px 32px rgba(31, 38, 135, 0.1);
      border: 1px solid rgba(255,255,255,0.2);
      margin-bottom: 2rem;
      text-align: center;
    }
    .feature-box i {
      margin-bottom: 1.5rem;
      opacity: 0.8;
    }
    .feature-box h4 {
      font-weight: 600;
      color: #1e293b;
      margin-bottom: 1rem;
    }
    .feature-box p {
      color: #64748b;
      font-weight: 400;
      line-height: 1.6;
    }
    .container-fluid {
      max-width: 1200px;
      margin: 0 auto;
    }
    .card-text {
      color: #64748b;
      line-height: 1.6;
    }
    small.text-muted {
      color: #94a3b8 !important;
      font-size: 0.85rem;
    }