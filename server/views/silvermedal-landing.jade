                  .sm-slide(style="background-image:url('/images/lsb/lsb_tight_1.gif')")
                  .sm-slide(style="background-image:url('/images/lsb/lsb_tight_2.gif')")
                  .sm-slide(style="background-image:url('/images/lsb/lsb_tight_3.gif')")
