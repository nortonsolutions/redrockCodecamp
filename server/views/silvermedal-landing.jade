    script(type='module' src='https://cdn.jsdelivr.net/npm/@google/model-viewer@3.5.0/dist/model-viewer.min.js')
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js')
    script.
      (function () {
        var mv = document.getElementById('smModel');
        if (!mv) return;
        var credit = document.getElementById('smModelCredit');
        var models = [
          { src: '/assets/blender/rodney_bending.glb', alt: 'Rodney swinging animation', name: 'Swinging animation', by: 'Rodney' },
          { src: '/assets/blender/Crocodile.glb', alt: 'Crocodile', name: 'Crocodile', by: 'Lincoln' },
          { src: '/assets/blender/catFish.glb', alt: 'Catfish', name: 'Catfish', by: 'Lincoln' },
          { src: '/assets/blender/daveDragon.glb', alt: 'Dragon', name: 'Dragon', by: 'Chris' },
          { src: '/assets/blender/whitehorse.glb', alt: 'White horse', name: 'White horse', by: 'Chris', animationIndex: 1 },
          { src: '/assets/blender/armor.glb', alt: 'Armor', name: 'Armor', by: 'Chris' },
          { src: '/assets/blender/thunderBlade.glb', alt: 'Thunder blade', name: 'Thunder blade', by: 'Chris' },
          { src: '/assets/blender/axe.glb', alt: 'Axe', name: 'Axe', by: 'Chris' },
          { src: '/assets/blender/elfgirl.glb', alt: 'Elf girl', name: 'Elf girl', by: 'Rodney' },
          { src: '/assets/blender/shopkeep.glb', alt: 'Shopkeeper', name: 'Shopkeeper', by: 'Chris' },
          { src: '/assets/blender/bridge.glb', alt: 'Bridge', name: 'Bridge', by: 'Steve' },
          { src: '/assets/blender/torch.glb', alt: 'Torch', name: 'Torch', by: 'Mike', animation: 'Fire' },
          { src: '/assets/blender/valley.glb', alt: 'Valley level', name: 'Valley level', by: 'Mike' }
        ];
        function showCredit() {
          if (!credit) return;
          credit.textContent = models[i].name + ' — by ' + models[i].by;
        }
        var i = 0;
        var interval = parseInt(mv.getAttribute('data-rotate-interval'), 10) || 450;
        var timer = null;
        function schedule() { clearTimeout(timer); timer = setTimeout(next, interval); }
        function next() {
          i = (i + 1) % models.length;
          mv.setAttribute('src', models[i].src);
          mv.setAttribute('alt', models[i].alt);
          showCredit();
        }
        // Each GLB exposes its clips on mv.availableAnimations. Set an entry's
        // `animation` (exact clip name) or `animationIndex` to choose / rotate it.
        function applyAnimation(entry) {
          try {
            var anims = mv.availableAnimations || [];
            if (!anims.length) return;
            var pick = null;
            if (entry.animation && anims.indexOf(entry.animation) !== -1) pick = entry.animation;
            else if (typeof entry.animationIndex === 'number' && anims[entry.animationIndex]) pick = anims[entry.animationIndex];
            if (pick && mv.animationName !== pick) { mv.animationName = pick; if (mv.play) mv.play(); }
          } catch (e) {}
        }
        mv.addEventListener('load', function () { applyAnimation(models[i]); schedule(); });
        showCredit();
        schedule();
      })();
    script.
      (function () {
        // Keep the model still but make it feel alive: it looks toward the cursor,
        // leans in (zoom) as the cursor nears the centre, brightens on hover, and —
        // for models with a flame/glow material (e.g. the torch) — actually lights up.
        var mv = document.getElementById('smModel');
        if (!mv) return;
        var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var base = { theta: 0, phi: 72, radius: 95 };          // radius in %
        var range = 18;                                        // orbit swing (deg)
        var zoomIn = 78, zoomOut = 100;                        // radius % at centre vs edge
        var baseExposure = 1.25, hoverExposure = 1.6, glowExposure = 2.2;
        var cur = { t: base.theta, p: base.phi, r: base.radius };
        var target = { t: base.theta, p: base.phi, r: base.radius };
        var raf = null, hovering = false;
        function setOrbit() {
          mv.cameraOrbit = cur.t.toFixed(1) + 'deg ' + cur.p.toFixed(1) + 'deg ' + cur.r.toFixed(1) + '%';
        }
        function loop() {
          cur.t += (target.t - cur.t) * 0.12;
          cur.p += (target.p - cur.p) * 0.12;
          cur.r += (target.r - cur.r) * 0.12;
          setOrbit();
          if (Math.abs(target.t - cur.t) > 0.05 || Math.abs(target.p - cur.p) > 0.05 || Math.abs(target.r - cur.r) > 0.05)
            raf = requestAnimationFrame(loop);
          else raf = null;
        }
        function queue() { if (!raf) raf = requestAnimationFrame(loop); }
        // Emissive "light up": scan each loaded model for flame/glow materials and
        // boost their emissive factor on hover (restored on leave). Re-scanned per model.
        var glowMats = [];
        function captureGlow() {
          glowMats = [];
          try {
            var mats = (mv.model && mv.model.materials) || [];
            mats.forEach(function (m) {
              var nm = (m.name || '').toLowerCase();
              if (/fire|flame|torch|ember|glow|lava|magma|light|emis|lamp|candle/.test(nm)) {
                glowMats.push({ m: m, orig: m.emissiveFactor ? m.emissiveFactor.slice() : [0, 0, 0] });
              }
            });
          } catch (e) {}
        }
        function setGlow(on) {
          glowMats.forEach(function (g) {
            try { g.m.setEmissiveFactor(on ? [1, 0.55, 0.18] : g.orig); } catch (e) {}
          });
        }
        function hasGlow() { return glowMats.length > 0; }
        mv.addEventListener('load', function () { captureGlow(); if (hovering) setGlow(true); });
        // Cursor-following orbit: intentionally outside the reduce-motion guard because
        // this motion is directly driven by the cursor (stops when the cursor stops) rather
        // than being an autonomous looping animation, so it doesn't trigger vestibular issues.
        mv.addEventListener('pointermove', function (e) {
          var r = mv.getBoundingClientRect();
          var dx = (e.clientX - (r.left + r.width / 2)) / (r.width / 2);
          var dy = (e.clientY - (r.top + r.height / 2)) / (r.height / 2);
          var dist = Math.min(2, Math.sqrt(dx * dx + dy * dy));
          target.t = base.theta + dx * range * 3;
          target.p = Math.max(40, Math.min(105, base.phi - dy * range));
          target.r = zoomIn + (zoomOut - zoomIn) * dist; // cursor near centre = lean in
          queue();
        });
        mv.addEventListener('pointerenter', function () {
          hovering = true;
          mv.exposure = hasGlow() ? glowExposure : hoverExposure;
          setGlow(true);
        });
        mv.addEventListener('pointerleave', function () {
          hovering = false;
          mv.exposure = baseExposure;
          setGlow(false);
          target.t = base.theta; target.p = base.phi; target.r = base.radius;
          queue();
        });
      })();
    script.
      (function () {
        var nav = document.getElementById('smNav');
        if (!nav) return;
        function hide() {
          bootstrap.Collapse.getOrCreateInstance(nav, { toggle: false }).hide();
        }
        document.addEventListener('click', function (e) {
          if (!nav.classList.contains('show')) return;
          if (e.target.closest('.sm-navbar')) return;
          hide();
        });
        nav.addEventListener('click', function (e) {
          if (e.target.closest('a.nav-link') && nav.classList.contains('show')) hide();
        });
      })();
    script.
      (function () {
        var rotators = document.querySelectorAll('.sm-rotator');
        Array.prototype.forEach.call(rotators, function (rot) {
          var slides = Array.prototype.slice.call(rot.querySelectorAll('.sm-slide'));
          if (!slides.length) return;
          var i = 0;
          var timer = null;
          var interval = parseInt(rot.getAttribute('data-rotate-interval'), 10) || 4000;
          function clear() { if (timer) { clearTimeout(timer); timer = null; } }
          function next() { activate((i + 1) % slides.length); }
          function activate(n) {
            var prev = slides[i];
            if (prev.tagName === 'VIDEO') { try { prev.pause(); } catch (e) {} }
            prev.classList.remove('is-active');
            i = n;
            var cur = slides[i];
            cur.classList.add('is-active');
            clear();
            if (cur.tagName === 'VIDEO') {
              try {
                cur.currentTime = 0;
                var p = cur.play();
                if (p && p.catch) { p.catch(function () { timer = setTimeout(next, interval); }); }
              } catch (e) { timer = setTimeout(next, interval); }
            } else {
              timer = setTimeout(next, interval);
            }
          }
          slides.forEach(function (s) {
            if (s.tagName === 'VIDEO') { s.addEventListener('ended', next); }
          });
          if (slides.length > 1 || slides[0].tagName === 'VIDEO') { activate(0); }
        });
      })();
    script.
      (function () {
        // Four Robes exhibit: lives on the page but loads responsibly — artwork is
        // fetched only when the section nears the viewport, and the cross-fade
        // pauses whenever it scrolls out of view (good net etiquette).
        var stage = document.getElementById('robesStage');
        if (!stage) return;
        var slides = Array.prototype.slice.call(stage.querySelectorAll('.sm-slide'));
        if (!slides.length) return;
        var i = 0, timer = null, loaded = false, visible = false;
        var interval = parseInt(stage.getAttribute('data-rotate-interval'), 10) || 4500;
        var saveData = navigator.connection && navigator.connection.saveData;
        function clear() { if (timer) { clearTimeout(timer); timer = null; } }
        function lazyLoad() {
          if (loaded) return;
          loaded = true;
          slides.forEach(function (s) {
            var bg = s.getAttribute('data-bg');
            if (bg) s.style.backgroundImage = "url('" + bg + "')";
          });
        }
        function schedule() {
          clear();
          if (visible && !saveData && slides.length > 1) {
            timer = setTimeout(function () {
              slides[i].classList.remove('is-active');
              i = (i + 1) % slides.length;
              slides[i].classList.add('is-active');
              schedule();
            }, interval);
          }
        }
        function start() { visible = true; lazyLoad(); schedule(); }
        function stop() { visible = false; clear(); }
        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (en) { en.isIntersecting ? start() : stop(); });
          }, { rootMargin: '200px 0px' });
          io.observe(stage);
        } else {
          start();
        }
      })();
    script.
      (function () {
        // Subtle parallax: nudge the hero backdrop with the mouse (and device tilt).
        // Uses a real <div.sm-hero-bg> so the transform is set directly via style.transform,
        // avoiding the CSS-custom-property + ::before + will-change combination that
        // fails silently in Firefox and some Safari/GPU compositing configurations.
        var heroBg = document.querySelector('.sm-hero-bg');
        if (!heroBg) return;
        //- if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        // Smooth parallax via a continuous lerp loop.
        // curX/Y trails tgX/Y at 7 % per frame — buttery smooth with a natural heavy-lag feel.
        // No CSS transition on the element; the loop is the only easing so they never fight.
        var maxShift = 30;
        var curX = 0, curY = 0, tgX = 0, tgY = 0, lerpId = null;
        function tick() {
          curX += (tgX - curX) * 0.07;
          curY += (tgY - curY) * 0.07;
          heroBg.style.webkitTransform = 'translate3d(' + curX.toFixed(3) + 'px,' + curY.toFixed(3) + 'px,0)';
          heroBg.style.transform       = 'translate3d(' + curX.toFixed(3) + 'px,' + curY.toFixed(3) + 'px,0)';
          lerpId = (Math.abs(tgX - curX) > 0.02 || Math.abs(tgY - curY) > 0.02)
            ? requestAnimationFrame(tick) : null;
        }
        function nudge() { if (!lerpId) lerpId = requestAnimationFrame(tick); }
        window.addEventListener('mousemove', function (e) {
          var cx = window.innerWidth / 2, cy = window.innerHeight / 2;
          tgX = ((e.clientX - cx) / cx) * maxShift;
          tgY = ((e.clientY - cy) / cy) * maxShift;
          nudge();
        }, { passive: true });
        window.addEventListener('deviceorientation', function (e) {
          if (e.gamma == null || e.beta == null) return;
          tgX = Math.max(-1, Math.min(1, e.gamma / 30)) * maxShift;
          tgY = Math.max(-1, Math.min(1, (e.beta - 45) / 30)) * maxShift;
          nudge();
        }, { passive: true });
      })();
    script(src='/js/silvermedal-workshops.js' defer)
