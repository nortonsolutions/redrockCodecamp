doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')

    link(rel='icon' type='image/png' href=branding.logoPath)

    meta(name='description' content='Silver Medal - Your gateway to innovative web solutions, coding education, interactive learning platforms, and community engagement.')
    meta(name='keywords' content='web development, coding education, online learning, JavaScript, Red Rock Code Academy, workshops, writers guild, life science balance')
    meta(name='author' content='Silver Medal')
    meta(name='robots' content='index, follow')
    link(rel='canonical' href=branding.homeUrl + '/')

    meta(property='og:title' content='Silver Medal - Innovative Web Solutions & Coding Education')
    meta(property='og:description' content='Your gateway to web development training, interactive platforms, and community engagement.')
    meta(property='og:type' content='website')
    meta(property='og:url' content=branding.homeUrl + '/')
    meta(property='og:image' content=branding.homeUrl + branding.logoPath)

    title #{branding.businessAppName} - Community of Creativity | Home
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css' rel='stylesheet')
    link(href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css' rel='stylesheet')

    style.
        :root {
          --sm-blue: #2563eb;
          --sm-purple: #7c3aed;
          --sm-green: #16a34a;
          --sm-red: #dc2626;
          --sm-ink: #0f1f33;
        }
        body { background: #f5f7fb; color: #1f2937; }
        html { scroll-behavior: smooth; scroll-padding-top: 84px; }
        section[id], header[id] { scroll-margin-top: 84px; }

        /* ---- Navbar ---- */
        .sm-navbar { background: linear-gradient(135deg, #0f1f33, #0b1626) !important; box-shadow: 0 2px 14px rgba(0,0,0,.18); }
        .sm-navbar .nav-link { color: #cdd7e6 !important; font-weight: 600; font-size: .82rem; letter-spacing: .04em; text-transform: uppercase; white-space: nowrap; display: flex; align-items: center; gap: .35rem; padding: .4rem .7rem; border-radius: 8px; transition: color .15s ease, background .15s ease; }
        .sm-navbar .nav-link i { font-size: .95rem; opacity: .85; }
        .sm-navbar .nav-link:hover, .sm-navbar .nav-link.active { color: #fff !important; background: rgba(255,255,255,.08); }
        .sm-navbar .nav-link:hover i, .sm-navbar .nav-link.active i { opacity: 1; }
        .sm-navbar .navbar-collapse.collapsing { transition: height .35s ease; }
        .sm-navbar .navbar-toggler { border: none; transition: transform .3s ease; }
        .sm-navbar .navbar-toggler:focus { box-shadow: none; }
        .sm-navbar .navbar-toggler[aria-expanded="true"] { transform: rotate(90deg); }
        @media (max-width: 991.98px) {
          .sm-navbar .navbar-collapse .navbar-nav,
          .sm-navbar .navbar-collapse > .d-flex { transition: opacity .35s ease, transform .35s ease; }
          .sm-navbar .navbar-collapse:not(.show) .navbar-nav,
          .sm-navbar .navbar-collapse:not(.show) > .d-flex { opacity: 0; transform: translateY(-10px); }
          .sm-navbar .navbar-collapse.show .navbar-nav,
          .sm-navbar .navbar-collapse.show > .d-flex { opacity: 1; transform: translateY(0); }
        }
        .sm-tagline { color: #8aa0bd; font-size: .66rem; letter-spacing: .12em; text-transform: uppercase; }
        .sm-brand-logo { border-radius: 50%; background: #fff; padding: 3px; object-fit: contain; }
        .sm-btn-support { background: linear-gradient(135deg, var(--sm-blue), #1d4ed8); color: #fff; border: none; }
        .sm-btn-support:hover { color: #fff; filter: brightness(1.08); }
        .sm-promo a { text-decoration: none; }

        /* ---- Hero with soft "silk-screen" mountains ---- */
        .sm-hero {
          position: relative; overflow: hidden; background-color: #e9edf6;
          background-size: cover;
          background-image: url('/images/mountain_background_detailed.png');  
          //- background-image:
          //-   linear-gradient(180deg, rgba(255,255,255,.45), rgba(245,247,251,.92)),
          //-   url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="%23aeb9da" d="M0 215 L240 110 L480 205 L720 95 L960 200 L1200 120 L1440 205 L1440 320 L0 320 Z"/><path fill="%238e9ccb" d="M0 255 L300 175 L600 250 L900 165 L1200 250 L1440 185 L1440 320 L0 320 Z"/></svg>'),
          //-   linear-gradient(120deg, #fde9dd 0%, #efe7f7 45%, #dceafb 100%);
          background-size: cover, 100% auto, cover;
          background-position: center, bottom, center;
          background-repeat: no-repeat;
        }
        .sm-hero-title { letter-spacing: -.5px; text-wrap: balance; }
        .sm-text-community { color: var(--sm-blue); }
        .sm-text-creativity { color: var(--sm-purple); }
        /* Spherical-logo rotator sits beside the heading via flex — no float, so no orphaned words */
        .sm-hero-head { gap: 1.25rem; }
        .sm-rotator.sm-hero-logo { position: relative; inset: auto; z-index: 1; flex: 0 0 auto; width: 248px; height: 248px; }
        .sm-rotator.sm-hero-logo .sm-slide { background-size: contain; background-repeat: no-repeat; }
        @media (max-width: 575.98px) { .sm-rotator.sm-hero-logo { width: 168px; height: 168px; } }
        /* ---- Hero CTA pills (two-line) ---- */
        .sm-pill {
          display: flex; flex-direction: column; justify-content: center;
          align-items: center; text-align: center;
          text-decoration: none; color: #fff; border-radius: 14px;
          padding: .7rem 1rem; min-height: 64px; height: 100%;
          box-shadow: 0 8px 20px rgba(15,31,51,.16);
          transition: transform .15s ease, box-shadow .15s ease, filter .15s ease;
        }
        .sm-pill:hover { transform: translateY(-3px); color: #fff; filter: brightness(1.05); box-shadow: 0 12px 26px rgba(15,31,51,.24); }
        .sm-pill-title { font-weight: 700; }
        .sm-pill-sub { font-size: .78rem; opacity: .9; }
        .sm-pill-blue { background: linear-gradient(135deg, #3b82f6, #2563eb); }
        .sm-pill-green { background: linear-gradient(135deg, #22c55e, #16a34a); }
        .sm-pill-purple { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }

        /* ---- Venn diagram (Community / Creativity / Calendar) ---- */
        .sm-venn { position: relative; width: 360px; height: 340px; max-width: 100%; margin: 0 auto; }
        .sm-circle {
          position: absolute; width: 214px; height: 214px; border-radius: 50%;
          display: flex; flex-direction: column; align-items: center;
          color: #fff; text-align: center; padding: 20px;
        }
        .sm-circle::before { content: ''; position: absolute; inset: 0; border-radius: 50%; background: var(--sm-circle); opacity: .82; mix-blend-mode: multiply; }
        .sm-circle > * { position: relative; z-index: 1; }
        .sm-c-label { font-weight: 700; letter-spacing: .08em; font-size: .82rem; }
        .sm-c-sub { font-size: .62rem; line-height: 1.25; opacity: .95; margin-top: 3px; max-width: 130px; }
        .sm-c-community { --sm-circle: var(--sm-blue); top: 0; left: 73px; justify-content: flex-start; }
        .sm-c-creativity { --sm-circle: var(--sm-purple); bottom: 0; left: 0; justify-content: flex-end; }
        .sm-c-calendar { --sm-circle: var(--sm-green); bottom: 0; right: 0; justify-content: flex-end; }
        .sm-venn-center {
          position: absolute; width: 122px; height: 122px; border-radius: 50%;
          left: 112px; top: 128px; background: #fff; z-index: 4;
          display: flex; flex-direction: column; align-items: center; justify-content: center;
          box-shadow: 0 10px 26px rgba(15,31,51,.22); border: 4px solid #fff;
        }
        .sm-venn-center img { width: 54px; height: 54px; object-fit: contain; }
        .sm-venn-center span { font-size: .56rem; font-weight: 700; letter-spacing: .06em; color: var(--sm-ink); margin-top: 2px; }

        /* ---- Destination cards ---- */
        //- #destinations {
        //-   background-size: cover;
        //-   background-image: url('/images/mountain_background_faded.png');
        //- }
        .sm-card { border: none; border-radius: 16px; overflow: hidden; height: 100%; background: #fff; box-shadow: 0 6px 18px rgba(15,31,51,.08); transition: transform .18s ease, box-shadow .18s ease; }
        .sm-card:hover { transform: translateY(-6px); box-shadow: 0 16px 32px rgba(15,31,51,.16); }
        .sm-card-media { height: 150px; background-size: cover; background-position: center; position: relative; display: flex; align-items: center; justify-content: center; }
        .sm-card-media::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(15,31,51,.05), rgba(15,31,51,.45)); }
        .sm-media-clean::after { display: none; }
        .sm-card-media video.sm-media-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
        .sm-media-icon { position: relative; z-index: 2; color: #fff; font-size: 2.6rem; text-shadow: 0 2px 10px rgba(0,0,0,.35); }
        /* Media rotator: cross-fades images and (optionally) plays a video as one slide */
        .sm-rotator { position: absolute; inset: 0; z-index: 0; }
        .sm-rotator .sm-slide { position: absolute; inset: 0; opacity: 0; transition: opacity .8s ease; background-size: cover; background-position: center; }
        .sm-rotator .sm-slide.is-active { opacity: 1; }
        .sm-rotator video.sm-slide { width: 100%; height: 100%; object-fit: cover; }
        /* Taller, squarer destination cards */
        

        #destinations .sm-card-media { 
          height: 300px; 
        }
        /* Live iframe project previews (animated remote demos) */
        .sm-card-media .sm-frame { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; z-index: 0; pointer-events: none; background: #fff; }
        /* Large "Four Robes" showcase rotator */
        .sm-robes-stage { position: relative; width: 100%; max-width: 860px; margin: 0 auto; height: clamp(360px, 52vw, 560px); border-radius: 20px; overflow: hidden; background: linear-gradient(135deg, #eef2fb, #e7ecfb); box-shadow: 0 14px 36px rgba(15,31,51,.16); }
        .sm-robes-stage .sm-slide { background-size: contain; background-repeat: no-repeat; }
        /* 3D model showcase (Blender GLBs via <model-viewer>) */
        .sm-model-media { background: radial-gradient(circle at 50% 30%, #1c3b27, #0b1d13); }
        .sm-model-media model-viewer { position: absolute; inset: 0; width: 100%; height: 100%; --poster-color: transparent; }
        /* Compact student-creation cards */
        .sm-card-sm .sm-card-media { height: 118px; }
        .sm-card-sm .card-body { padding: 1rem !important; }
        .sm-card-sm h5 { font-size: 1.02rem; }
        .sm-card-sm .sm-tag { font-size: .74rem; }
        .sm-card-sm .btn { font-size: .8rem; }
        .sm-card-sm .sm-media-icon { font-size: 2rem; }
        .sm-media-blue { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
        .sm-media-red { background: linear-gradient(135deg, #f87171, #dc2626); }
        .sm-media-green { background: linear-gradient(135deg, #34d399, #16a34a); }
        .sm-media-purple { background: linear-gradient(135deg, #a78bfa, #7c3aed); }
        .sm-media-teal { background: linear-gradient(135deg, #2dd4bf, #0d9488); }
        .sm-media-indigo { background: linear-gradient(135deg, #818cf8, #4f46e5); }
        .sm-tag { font-weight: 700; font-size: .82rem; letter-spacing: .02em; }
        .sm-tag-blue { color: var(--sm-blue); }
        .sm-tag-red { color: var(--sm-red); }
        .sm-tag-green { color: var(--sm-green); }
        .sm-tag-purple { color: var(--sm-purple); }
        .sm-tag-teal { color: #0d9488; }
        .sm-tag-indigo { color: #4f46e5; }
        .section-rule { height: 4px; width: 64px; border-radius: 2px; background: var(--sm-blue); }

        /* ---- "Built on Purpose" stats + CTA ---- */
        .sm-panel { border-radius: 18px; background: #fff; box-shadow: 0 6px 18px rgba(15,31,51,.08); }
        .sm-cta { border-radius: 18px; background: linear-gradient(135deg, #eaf1ff, #e7ecfb); border: 1px solid #dbe4f7; }
        .sm-stat-icon { font-size: 1.5rem; color: var(--sm-blue); }

        /* ---- Workshops ---- */
        .workshop-card { border: 1px solid rgba(0,0,0,.06); border-left-width: 5px; border-radius: 14px; transition: transform .15s ease, box-shadow .15s ease; }
        .workshop-card:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,.08); }
        .workshop-card.cat-writing { border-left-color: var(--sm-purple); }
        .workshop-card.cat-health  { border-left-color: var(--sm-green); }
        .workshop-card.cat-coding  { border-left-color: var(--sm-blue); }
        .badge-writing { background-color: var(--sm-purple); }
        .badge-health  { background-color: var(--sm-green); }
        .badge-coding  { background-color: var(--sm-blue); }
        .workshop-filter .btn.active { color: #fff; background-color: var(--sm-blue); border-color: var(--sm-blue); }

        /* ---- Footer ---- */
        .sm-footer { background: var(--sm-ink); border-top: 4px solid var(--sm-blue); }
        .sm-footer a { color: #aebbd0; text-decoration: none; transition: color .2s ease; }
        .sm-footer a:hover { color: #fff; }
        .sm-social a { font-size: 1.15rem; }

        @media (max-width: 575.98px) {
          .sm-venn { width: 300px; height: 300px; }
          .sm-circle { width: 182px; height: 182px; }
          .sm-c-community { left: 59px; }
          .sm-venn-center { width: 104px; height: 104px; left: 98px; top: 116px; }
        }

  body
    // ===== Top navigation =====
    nav.navbar.navbar-expand-lg.navbar-dark.sm-navbar.py-2.sticky-top
      .container
        a.navbar-brand.d-flex.align-items-center.gap-2.py-0(href='/')
          img.sm-brand-logo(src=branding.logoPath alt=branding.businessName width='44' height='44')
          span.d-flex.flex-column.lh-1
            span.fw-bold.fs-5.text-white #{branding.businessName}
            span.sm-tagline Community · Creativity · Calendar
        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#smNav' aria-label='Toggle navigation')
          span.navbar-toggler-icon
        #smNav.collapse.navbar-collapse
          ul.navbar-nav.mx-auto.align-items-lg-center
            li.nav-item
              a.nav-link.active(href='/')
                i.bi.bi-house-door-fill
                span Home
            li.nav-item
              a.nav-link(href='#destinations')
                i.bi.bi-grid-1x2-fill
                span Projects
            li.nav-item
              a.nav-link(href='#creations')
                i.bi.bi-stars
                span Creations
            li.nav-item
              a.nav-link(href='#workshops')
                i.bi.bi-calendar-event-fill
                span Classes &amp; Events
            li.nav-item
              a.nav-link(href='/about.html')
                i.bi.bi-info-circle-fill
                span About
            li.nav-item
              a.nav-link(href='mailto:dave@silvermedal.net')
                i.bi.bi-envelope-fill
                span Contact
          .d-flex.gap-2.ms-lg-3.mt-3.mt-lg-0
            a.btn.btn-outline-light.btn-sm.rounded-pill.px-3(href=continueUrl)
              if user
                | Resume Academy
              else
                | Enter Academy
            a.btn.sm-btn-support.btn-sm.rounded-pill.px-3(href='/donate.html')
              i.bi.bi-heart-fill.me-1
              | Support

    // ===== Slim promo strip (retained "New Lesson" highlight) =====
    .sm-promo.bg-primary.bg-gradient.text-white.py-2.small
      .container.d-flex.flex-wrap.align-items-center.justify-content-center.gap-2.text-center
        span 🎮 New Lesson — Platform Game Extensions
        a.text-white.fw-bold(href='/en/challenges/beginning-web-development-projects/platform-game-extensions') Start Learning →

    // ===== Hero =====
    header.sm-hero
      .container.py-5
        .row.align-items-center.g-5
          .col-lg-6
            .d-flex.flex-column.flex-sm-row.align-items-center.text-center.text-sm-start.sm-hero-head.mb-3
              .sm-rotator.sm-hero-logo(data-rotate-interval='4000' role='img' aria-label=branding.businessName)
                .sm-slide.is-active(style="background-image:url('/images/silvermedal/silvermedal5.png')")
                .sm-slide(style="background-image:url('/images/silvermedal/silvermedal6.png')")
                .sm-slide(style="background-image:url('/images/silvermedal/silvermedal7.png')")
                .sm-slide(style="background-image:url('/images/silvermedal/silvermedal8.png')")
              h1.display-4.fw-bold.sm-hero-title.mb-0
                | A culture of
                br
                span.sm-text-community community
                |  and 
                span.sm-text-creativity creativity.
            p.lead.text-secondary.mb-2
              | #{branding.businessName} is an ecosystem of tools that help people create, build, and improve their lives.
            p.fw-bold.fs-5.text-dark.mb-4 We help to build creators.
            .row.g-3.sm-hero-cta
              .col-sm-4
                a.sm-pill.sm-pill-blue(href='#destinations')
                  span.sm-pill-title Explore Projects
                  span.sm-pill-sub See what we're building
              .col-sm-4
                a.sm-pill.sm-pill-green(href=continueUrl)
                  if user
                    span.sm-pill-title Resume Academy
                  else
                    span.sm-pill-title Enter the Academy
                  span.sm-pill-sub Learn, build, and grow
              .col-sm-4
                a.sm-pill.sm-pill-purple(href='#workshops')
                  span.sm-pill-title Classes &amp; Events
                  span.sm-pill-sub Grow your skills
            if user
              p.small.text-muted.mt-3.mb-0 Signed in as #{user.name || user.username}. Pick up where you left off.
          .col-lg-6
            // Community / Creativity / Calendar Venn with the Silver Medal logo at center
            .sm-venn
              .sm-circle.sm-c-community
                span.sm-c-label COMMUNITY
                span.sm-c-sub Connecting people who want to learn, share, and grow together.
              .sm-circle.sm-c-creativity
                span.sm-c-label CREATIVITY
                span.sm-c-sub Empowering creators to build ideas, projects, and solutions.
              .sm-circle.sm-c-calendar
                span.sm-c-label CALENDAR
                span.sm-c-sub Classes, events, and knowledge for self-improvement.
              .sm-venn-center
                img(src=branding.logoPath alt=branding.businessName)
                span SILVER MEDAL

    // ===== Featured destinations =====
    //- Swap any card image by editing the background-image / sm-media-* class.
    //- Available art lives under /assets/graphics/ (silvermedal_*, rrcc_shots_*, codebasecamp_*).
    section#destinations.py-5
      .container
        .text-center.mb-5
          h2.fw-bold.text-dark.mb-2 Our Projects &amp; Communities
          .section-rule.mx-auto
        .row.g-4
          .col-md-6.col-lg-4
            .sm-card.d-flex.flex-column
              .sm-card-media.sm-media-red.sm-media-clean
                //- Rotator: edit the image filenames/count to match what you place in /assets/images.
                .sm-rotator(data-rotate-interval='4500')
                  .sm-slide.is-active(style="background-image:url('/assets/images/redrockcode_1.png')")
                  .sm-slide(style="background-image:url('/assets/images/redrockcode_2.png')")
                  .sm-slide(style="background-image:url('/assets/images/redrockcode_3.png')")
                  .sm-slide(style="background-image:url('/assets/images/redrockcode_4.png')")
                  .sm-slide(style="background-image:url('/assets/images/redrockcode_5.png')")
                  .sm-slide(style="background-image:url('/assets/images/redrockcode_6.png')")
              .card-body.d-flex.flex-column.p-4
                h5.fw-bold.mb-1 Red Rock Code
                p.sm-tag.sm-tag-red.mb-2 Build. Solve. Elevate.
                p.text-muted.small.mb-4 A hands-on coding academy plus custom software, websites, and solutions that turn ideas into reality.
                a.btn.btn-outline-danger.fw-semibold.mt-auto.rounded-pill.px-4.align-self-start(href=continueUrl) Start Learning →
          .col-md-6.col-lg-4
            .sm-card.d-flex.flex-column
              .sm-card-media.sm-media-green.sm-media-clean
                .sm-rotator(data-rotate-interval='3200')
