    script.
      (function () {
        var mv = document.getElementById('smModel');
        if (!mv) return;
        var credit = document.getElementById('smModelCredit');
        var models = [
          { src: '/assets/blender/rodney_bending.glb', alt: 'Rodney swinging animation', name: 'Swinging animation', by: 'Rodney' },
          { src: '/assets/blender/Crocodile.glb', alt: 'Crocodile', name: 'Crocodile', by: 'Lincoln' },
          { src: '/assets/blender/catFish.glb', alt: 'Catfish', name: 'Catfish', by: 'Lincoln' },
          { src: '/assets/blender/daveDragon.glb', alt: 'Dragon', name: 'Dragon', by: 'Chris' },
          { src: '/assets/blender/whitehorse.glb', alt: 'White horse', name: 'White horse', by: 'Chris' },
          { src: '/assets/blender/armor.glb', alt: 'Armor', name: 'Armor', by: 'Chris' },
          { src: '/assets/blender/thunderBlade.glb', alt: 'Thunder blade', name: 'Thunder blade', by: 'Chris' },
          { src: '/assets/blender/axe.glb', alt: 'Axe', name: 'Axe', by: 'Chris' },
          { src: '/assets/blender/elfgirl.glb', alt: 'Elf girl', name: 'Elf girl', by: 'Rodney' },
          { src: '/assets/blender/shopkeep.glb', alt: 'Shopkeeper', name: 'Shopkeeper', by: 'Rodney' },
          { src: '/assets/blender/bridge.glb', alt: 'Bridge', name: 'Bridge', by: 'Steve' },
          { src: '/assets/blender/torch.glb', alt: 'Torch', name: 'Torch', by: 'Mike' },
          { src: '/assets/blender/valley.glb', alt: 'Valley level', name: 'Valley level', by: 'Mike' }
        ];
        function showCredit() {
          if (!credit) return;
          credit.textContent = models[i].name + ' — by ' + models[i].by;
        }
        var i = 0;
        var interval = parseInt(mv.getAttribute('data-rotate-interval'), 10) || 4500;
        var timer = null;
        function schedule() { clearTimeout(timer); timer = setTimeout(next, interval); }
        function next() {
          i = (i + 1) % models.length;
          mv.setAttribute('src', models[i].src);
          mv.setAttribute('alt', models[i].alt);
          showCredit();
        }
        mv.addEventListener('load', schedule);
        showCredit();
        schedule();
      })();
    script.
      (function () {
        var nav = document.getElementById('smNav');
        if (!nav) return;
        function hide() {
          bootstrap.Collapse.getOrCreateInstance(nav, { toggle: false }).hide();
        }
        document.addEventListener('click', function (e) {
          if (!nav.classList.contains('show')) return;
          if (e.target.closest('.sm-navbar')) return;
          hide();
        });
        nav.addEventListener('click', function (e) {
          if (e.target.closest('a.nav-link') && nav.classList.contains('show')) hide();
        });
      })();
    script.
      (function () {
        var rotators = document.querySelectorAll('.sm-rotator');
        Array.prototype.forEach.call(rotators, function (rot) {
          var slides = Array.prototype.slice.call(rot.querySelectorAll('.sm-slide'));
          if (!slides.length) return;
          var i = 0;
          var timer = null;
          var interval = parseInt(rot.getAttribute('data-rotate-interval'), 10) || 4000;
          function clear() { if (timer) { clearTimeout(timer); timer = null; } }
          function next() { activate((i + 1) % slides.length); }
          function activate(n) {
            var prev = slides[i];
            if (prev.tagName === 'VIDEO') { try { prev.pause(); } catch (e) {} }
            prev.classList.remove('is-active');
            i = n;
            var cur = slides[i];
            cur.classList.add('is-active');
            clear();
            if (cur.tagName === 'VIDEO') {
              try {
                cur.currentTime = 0;
                var p = cur.play();
                if (p && p.catch) { p.catch(function () { timer = setTimeout(next, interval); }); }
              } catch (e) { timer = setTimeout(next, interval); }
            } else {
              timer = setTimeout(next, interval);
            }
          }
          slides.forEach(function (s) {
            if (s.tagName === 'VIDEO') { s.addEventListener('ended', next); }
          });
          if (slides.length > 1 || slides[0].tagName === 'VIDEO') { activate(0); }
        });
      })();
