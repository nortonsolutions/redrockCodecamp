                  .sm-slide(style="background-image:url('/images/lsb/lsb_tight_9.gif')")
                  .sm-slide(style="background-image:url('/images/lsb/lsb_tight_10.gif')")
                  .sm-slide(style="background-image:url('/images/lsb/lsb_tight_11.gif')")
                  .sm-slide(style="background-image:url('/images/lsb/lsb_tight_12.gif')")
                  .sm-slide(style="background-image:url('/images/lsb/lsb_tight_13.gif')")
                  .sm-slide(style="background-image:url('/images/lsb/lsb_tight_14.gif')")
                  .sm-slide(style="background-image:url('/images/lsb/lsb_tight_15.gif')")
              .card-body.d-flex.flex-column.p-4
                h5.fw-bold.mb-1 Life Science Balance
                p.sm-tag.sm-tag-green.mb-2 Mind. Body. Energy.
                p.text-muted.small.mb-4 Wellness education and bioenergetic tools, combining science and holistic approaches for a balanced life.
                .mt-auto.d-flex.flex-column.gap-2.align-items-start
                  a.btn.btn-outline-success.fw-semibold.rounded-pill.px-4(href='https://lifesciencebalance.co' target='_blank' rel='noopener') Explore Wellness →
                  a.btn.btn-sm.btn-light.text-success.border-success.rounded-pill.px-3(href='https://lifesciencebalance.store/course/life-science-balance' target='_blank' rel='noopener') Take the Quiz
          .col-md-6.col-lg-4
            .sm-card.d-flex.flex-column
              .sm-card-media.sm-media-green.sm-media-clean
                .sm-rotator(data-rotate-interval='3200')
                  .sm-slide.is-active(style="background-image:url('/images/writersGuild/writersGuild_firefly_1.png')")
                  .sm-slide(style="background-image:url('/images/writersGuild/writersGuild_firefly_2.png')")
                  .sm-slide(style="background-image:url('/images/writersGuild/writersGuild_firefly_3.png')")
                  .sm-slide(style="background-image:url('/images/writersGuild/writersGuild_firefly_4.png')")
                  .sm-slide(style="background-image:url('/images/writersGuild/writersGuild_firefly_5.png')")
